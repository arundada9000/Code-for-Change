# ── Core ────────────────────────────────────
NODE_ENV='development'
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database ────────────────────────────────
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/CodeForChange?retryWrites=true&w=majority&appName=Cluster0"

# ── JWT ─────────────────────────────────────
JWT_SECRET=<your_jwt_secret_min_32_chars>
JWT_EXPIRES_IN=1d

# ── Admin Seeding ────────────────────────────
ADMIN_EMAIL=sajhilodigital@gmail.com
ADMIN_PASSWORD=Admin@2025Secure!
# ADMIN_EMAIL_2=codeforchange@gmail.com
# ADMIN_PASSWORD_2=codeforchange1234@#

# ── SMTP / Email ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_email@gmail.com>
SMTP_PASS=<your_gmail_app_password>

# ── Cloudinary ──────────────────────────────
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>

# ── WebAuthn / Passkeys ──────────────────────
WEBAUTHN_RP_ID=codeforchangenepal.com
WEBAUTHN_RP_NAME=Code for Change Nepal

# ── Push Notifications (generate via `node generate-vapid.cjs`) ──
VAPID_PUBLIC_KEY=<your_vapid_public_key>
VAPID_PRIVATE_KEY=<your_vapid_private_key>

# ── Payment (eSewa) ─────────────────────────
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=your_esewa_secret_key_here
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFICATION_URL=https://uat.esewa.com.np/api/epay/main/v2/verify

# ── Redis (optional) ────────────────────────
# REDIS_URL=redis://127.0.0.1:6379
# ENABLE_REDIS=false
